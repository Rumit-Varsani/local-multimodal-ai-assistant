OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_TAGS_URL=http://127.0.0.1:11434/api/tags
OLLAMA_MODEL=phi3:mini
OLLAMA_TIMEOUT_SECONDS=180

ASSISTANT_API_URL=http://127.0.0.1:8000/assistant
ASSISTANT_REQUEST_TIMEOUT_SECONDS=180
UI_AUTO_REFRESH_SECONDS=10
STREAMLIT_HOST=127.0.0.1
STREAMLIT_PORT=8501

# FastAPI bind settings for the machine that actually runs the backend.
# On the Dell server, use HOST=0.0.0.0 so the API can be reached remotely.
ASSISTANT_HOST=127.0.0.1
ASSISTANT_PORT=8000

# Background autonomy worker settings.
AUTONOMY_AUTO_START=false
AUTONOMY_POLL_SECONDS=30
AUTONOMY_ENABLE_TEACHER_SYNTHESIS=true
AUTONOMY_TEACHER_MAX_SAMPLES=5

# Training command template used when Phase 1 generates a runnable training plan.
FORGEMIND_TRAIN_COMMAND=python train_forgemind.py --dataset {dataset_path} --strategy {strategy}

# Dell-hosted UI recommendation:
# - On Dell, keep ASSISTANT_API_URL=http://127.0.0.1:8000/assistant
# - On Dell, use STREAMLIT_HOST=0.0.0.0
# - Then open http://<DELL_IP>:8501 from your Mac browser
