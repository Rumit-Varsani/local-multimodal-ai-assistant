from fai import FastAPI
import requests
from memory.memory import store_memory, search_memory

app = FastAPI()

OLLAMA_API = "http://127.0.0.1:11434/api/generate"


@app.get("/")
def home():
    return {"status": "AI server running"}


@app.post("/chat")
def chat(prompt: str):

    past_memory = search_memory(prompt)

    context = ""

    if past_memory:
        context = "Relevant past memory: " + str(past_memory)

    full_prompt = context + "\nUser: " + prompt

    response = requests.post(
        OLLAMA_API,
        json={
            "model": "phi3",
            "prompt": full_prompt,
            "stream": False
        }
    )

